{
  "mcpServers": {
    "mcp-server-default": {
      "command": "<command>",
      "args": [
        "<arg1>",
        "<arg2>"
      ],
      "alwaysAllow": []
    }
    ,
    "sequentialthinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "alwaysAllow": ["sequentialthinking"]
    }
  }
}
