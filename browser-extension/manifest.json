{
  "manifest_version": 3,
  "name": "SENTINNELL PLAY NOW Helper",
  "version": "1.0.0",
  "description": "Send video URLs and cookies to SENTINNELL PLAY NOW for downloading",
  "permissions": ["cookies", "activeTab"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.bilibili.com/*",
    "*://*.twitch.tv/*",
    "*://*.vimeo.com/*",
    "*://*.dailymotion.com/*",
    "*://*.nicovideo.jp/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.facebook.com/*",
    "*://*.reddit.com/*",
    "*://*.soundcloud.com/*",
    "*://*.bandcamp.com/*",
    "*://*.crunchyroll.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.bilibili.com/*",
        "*://*.twitch.tv/*",
        "*://*.vimeo.com/*",
        "*://*.dailymotion.com/*",
        "*://*.nicovideo.jp/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*",
        "*://*.facebook.com/*",
        "*://*.reddit.com/*",
        "*://*.soundcloud.com/*",
        "*://*.bandcamp.com/*",
        "*://*.crunchyroll.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
